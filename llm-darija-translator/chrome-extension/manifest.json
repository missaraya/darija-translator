{
  "manifest_version": 3,
  "name": "Darija Translator",
  "version": "1.0.0",
  "description": "Translate selected text to Moroccan Arabic Dialect (Darija) using AI.",

  "permissions": [
    "contextMenus",
    "storage",
    "sidePanel",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "http://localhost:*/*",
    "https://*/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_title": "Darija Translator",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
